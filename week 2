students = []

while True:
    print("\n1. Add Student")
    print("2. View Students")
    print("3. Exit")

    choice = input("Enter choice: ")

    if choice == "1":
        name = input("Enter Name: ")
        marks = input("Enter Marks: ")
        students.append({"name": name, "marks": marks})
        print("Student added")

    elif choice == "2":
        print(students)

    elif choice == "3":
        break

    else:
        print("Invalid choice")

